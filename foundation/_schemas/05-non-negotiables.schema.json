{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solomon.local/foundation/05-non-negotiables.schema.json",
  "title": "05-non-negotiables",
  "description": "Hard rules read deterministically by Pipeline Stage 4. Each rule has a JSON-logic condition.",
  "type": "object",
  "required": ["rules"],
  "additionalProperties": true,
  "properties": {
    "last_updated": { "type": ["string", "null"], "format": "date-time" },
    "raw_notes": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "domain", "condition", "on_violate"],
        "properties": {
          "id":        { "type": "string", "description": "ulid linking back to captured_items.id" },
          "statement": { "type": "string", "minLength": 1 },
          "domain":    { "type": "string" },
          "condition": { "description": "JSON-logic expression; evaluated by json-logic-py" },
          "on_violate": {
            "type": "object",
            "required": ["action", "explanation"],
            "properties": {
              "action":      { "type": "string", "enum": ["REJECT","DOWNGRADE","WARN"] },
              "explanation": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
